# ======================
# STORAGE - LOCAL (Development)
# ======================
[[r2_buckets]]
binding = "STORAGE"
bucket_name = "xora-social-media-local"

[[r2_buckets]]
binding = "SNAPSHOTS"
bucket_name = "xora-social-snapshots-local"

# ======================
# KV - LOCAL (Development)
# ======================
[[kv_namespaces]]
binding = "CACHE"
id = "d81a700a2125496e80ce1c018d4e3adb"
preview_id = "a932c77a3de24c80bc73e46d11e15f73"

# ======================
# DURABLE OBJECTS
# ======================
[[durable_objects.bindings]]
name = "CHAT_ROOM"
class_name = "ChatRoom"

[[durable_objects.bindings]]
name = "NOTIFICATION_HUB"
class_name = "NotificationHub"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["ChatRoom", "NotificationHub"]

